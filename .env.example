# API Configuration
# The URL of the image processing API worker endpoint
VITE_API_WORKER_URL=http://localhost:8787/api/erase-object-in-image

# Environment mode
# Values: development, production
VITE_ENV=production

# Request timeout in milliseconds
VITE_REQUEST_TIMEOUT=60000

# Debug logging
# Values: true, false
VITE_DEBUG=false